{
  "name": "@prescriptive/xote",
  "version": "0.2.0",
  "description": "Accessible UI components for Xote/ReScript that implement the Prescriptive contracts. Styled against @prescriptive/tokens; prop types are generated from the spec API contracts, so the implementation can't drift from the spec.",
  "license": "MIT",
  "author": "brnrdog",
  "keywords": [
    "rescript",
    "xote",
    "components",
    "ui",
    "design-system",
    "prescriptive",
    "accessibility"
  ],
  "type": "module",
  "files": [
    "src",
    "lib/ocaml",
    "rescript.json",
    "README.md"
  ],
  "scripts": {
    "contracts": "node scripts/generate-contracts.mjs",
    "build": "npm run contracts && rescript build",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@rescript/core": ">=1.6.0",
    "rescript": ">=12.0.0",
    "rescript-signals": ">=3.0.0",
    "xote": ">=7.0.0"
  },
  "dependencies": {
    "@prescriptive/tokens": "^0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brnrdog/prescriptive",
    "directory": "packages/xote"
  },
  "publishConfig": {
    "access": "public"
  }
}
