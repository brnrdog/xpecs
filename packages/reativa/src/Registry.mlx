      IconButton.make ~label:"Italic" ~children:[ el ~cls:"italic" "span" [ txt "I" ] ] ();
      IconButton.make ~label:"Underline" ~children:[ el ~cls:"underline" "span" [ txt "U" ] ] ();
      Separator.make ~orientation:`vertical ~extra_class:"mx-1" ();
      IconButton.make ~label:"Align left" ~children:[ Icon.make ~name:"align-left" () ] ();
      IconButton.make ~label:"Align center" ~children:[ Icon.make ~name:"align-center" () ] ();
      IconButton.make ~label:"Align right" ~children:[ Icon.make ~name:"align-right" () ] ();
      el ~cls:"ml-auto" "div"
        [ Button.make ~variant:`primary ~children:[ txt "Share" ] () ];
    ]

let footer_example () =
  let col title items =
    el ~cls:"space-y-2" "div"
      (el ~cls:"text-xs font-semibold uppercase tracking-wide text-neutral-500" "p" [ txt title ]
       :: List.map
            (fun i ->
              el "p"
                [ Link_.make ~href:"#" ~variant:`muted ~extra_class:"text-sm" ~children:[ txt i ] () ])
            items)
  in
  el ~cls:"w-full max-w-2xl rounded-lg border border-neutral-200 bg-surface p-6" "div"
    [
      el ~cls:"grid grid-cols-3 gap-6" "div"
        [
          col "Product" [ "Features"; "Pricing"; "Changelog" ];
          col "Company" [ "About"; "Blog"; "Careers" ];
          col "Legal" [ "Privacy"; "Terms" ];
        ];
      Separator.make ~extra_class:"my-5" ();
      el ~cls:"flex items-center justify-between text-xs text-neutral-500" "div"
        [
          txt "\xc2\xa9 2026 Acme, Inc.";
          el ~cls:"flex gap-3" "div"
            [
              Link_.make ~href:"#" ~variant:`muted ~children:[ txt "Twitter" ] ();
              Link_.make ~href:"#" ~variant:`muted ~children:[ txt "GitHub" ] ();
            ];
        ];
    ]

