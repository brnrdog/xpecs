let pricing_table_example () =
  let rows =
    [
      ("Projects", "1", "Unlimited", "Unlimited");
      ("Support", "Community", "Priority", "Dedicated");
      ("SSO", "\xe2\x80\x93", "\xe2\x80\x93", "\xe2\x9c\x93");
      ("Audit log", "\xe2\x80\x93", "\xe2\x9c\x93", "\xe2\x9c\x93");
    ]
  in
  (* Cells carry either plain text or a yes/no marker; render markers as icons. *)
  let cell_node v =
    match v with
    | "\xe2\x9c\x93" ->
      Icon.make ~name:"check" ~size:`sm ~label:"Included" ~extra_class:"mx-auto text-status-success" ()
    | "\xe2\x80\x93" ->
      Icon.make ~name:"minus" ~size:`sm ~label:"Not included" ~extra_class:"mx-auto text-neutral-300" ()
    | _ -> txt v
  in
  let th cls label = el ~cls "th" label in
  el ~cls:"w-full max-w-2xl overflow-hidden rounded-lg border border-neutral-200" "div"
    [
      el ~cls:"w-full text-sm" "table"
        [
          el ~cls:"bg-neutral-50" "thead"
            [
              el "tr"
                [
                  th "px-4 py-3 text-left text-xs uppercase tracking-wide text-neutral-500"
                    [ txt "Feature" ];
                  th "px-4 py-3 text-center font-medium" [ txt "Starter" ];
                  th "px-4 py-3 text-center font-medium"
                    [
                      el ~cls:"flex items-center justify-center gap-2" "div"
                        [ txt "Pro"; Badge.make ~variant:`solid ~children:[ txt "Popular" ] () ];
                    ];
                  th "px-4 py-3 text-center font-medium" [ txt "Team" ];
                ];
            ];
          el ~cls:"divide-y divide-neutral-100 text-neutral-700" "tbody"
            (List.map
               (fun (feat, a, b, c) ->
                 el "tr"
                   [
                     el ~cls:"px-4 py-2 font-medium text-neutral-900" "td" [ txt feat ];
                     el ~cls:"px-4 py-2 text-center" "td" [ cell_node a ];
                     el ~cls:"px-4 py-2 text-center" "td" [ cell_node b ];
                     el ~cls:"px-4 py-2 text-center" "td" [ cell_node c ];
                   ])
               rows
            @ [
                el "tr"
                  [
                    el ~cls:"px-4 py-3" "td" [];
                    el ~cls:"px-4 py-3 text-center" "td"
                      [ Button.make ~variant:`secondary ~children:[ txt "Choose" ] () ];
                    el ~cls:"px-4 py-3 text-center" "td"
                      [ Button.make ~variant:`primary ~children:[ txt "Choose" ] () ];
                    el ~cls:"px-4 py-3 text-center" "td"
                      [ Button.make ~variant:`secondary ~children:[ txt "Choose" ] () ];
                  ];
              ]);
        ];
    ]

let faq_example () =
  let open_id = Signal.make 0 in
  let items =
    [
      (0, "Can I cancel anytime?", "Yes \xe2\x80\x94 cancel in one click, no questions asked.");
      (1, "Do you offer refunds?", "We offer a 30-day money-back guarantee.");
      (2, "Is there a free plan?", "Yes, the Starter plan is free forever.");
    ]
  in
  el ~cls:"w-full max-w-xl divide-y divide-neutral-200 rounded-lg border border-neutral-200" "div"
    (List.map
       (fun (idx, q, a) ->
         let is_open () = Signal.get open_id = idx in
         el "div"
           [
             View.element
               ~attrs:
                 [
                   View.Attr.className
                     (View.static
                        "flex w-full items-center justify-between px-4 py-3 text-left text-sm \
                         font-medium text-neutral-800 hover:bg-neutral-50");
                 ]
               ~events:
                 [
                   View.On.click (fun _ ->
                       Signal.update open_id (fun c -> if c = idx then -1 else idx));
                 ]
               "button"
               [
                 txt q;
                 el ~cls:"text-neutral-400" "span"
                   [
                     View.show ~fallback:(Icon.make ~name:"plus" ~size:`sm ()) is_open
                       (Icon.make ~name:"minus" ~size:`sm ());
                   ];
               ];
             View.show is_open (el ~cls:"px-4 pb-3 text-sm text-neutral-500" "p" [ txt a ]);
           ])
       items)

