let stat_grid_example () =
  let loading = Signal.make false in
  let stats =
    [
      ("Revenue", "$48.2k", "+12% vs. last month", `up);
      ("Active users", "1,203", "+3% vs. last month", `up);
      ("Signups", "312", "\xe2\x88\x925% vs. last month", `down);
      ("Uptime", "99.98%", "flat vs. last month", `flat);
    ]
  in
  <div className="w-full max-w-2xl space-y-3">
    (View.show
       ~fallback:(StatGrid.make ~heading:"This month" ~stats ())
       (fun () -> Signal.get loading)
       (StatGrid.make ~heading:"This month" ~stats ~loading:true ()))
    (Button.make ~variant:`secondary ~size:`sm
       ~on_click:(fun _ ->
         Signal.set loading true;
         Ui.set_timeout (fun () -> Signal.set loading false) 1500)
       ~children:[ txt "Simulate loading" ] ())
  </div>

