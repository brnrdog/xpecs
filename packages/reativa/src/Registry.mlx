    [
      ("Ada Lovelace", "@ada", "Owner", "AL");
      ("Grace Hopper", "@grace", "Admin", "GH");
      ("Alan Turing", "@alan", "Member", "AT");
    ]
  in
  el ~cls:"w-80 divide-y divide-neutral-100 rounded-lg border border-neutral-200 bg-surface" "div"
    (List.map
       (fun (name, handle, role, initials) ->
         el ~cls:"flex items-center gap-3 px-4 py-3" "div"
           [
             Avatar.make ~initials ~size:"size-9 text-xs" ();
             el ~cls:"min-w-0 flex-1" "div"
               [
                 el ~cls:"truncate text-sm font-medium text-neutral-900" "p" [ txt name ];
                 el ~cls:"text-xs text-neutral-500" "p" [ txt handle ];
