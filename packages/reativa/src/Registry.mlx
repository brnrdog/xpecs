let pagination_example () =
  let page = Signal.make 2 in
  let nav_btn =
    "inline-flex size-9 items-center justify-center rounded-md text-sm transition-colors"
  in
  let arrow name step =
    View.element
      ~attrs:
        [
          View.Attr.className
            (View.static (nav_btn ^ " border border-neutral-300 text-neutral-700 hover:bg-neutral-100"));
        ]
      ~events:[ View.On.click (fun _ -> Signal.update page step) ]
      "button"
      [ Icon.make ~name ~size:`sm () ]
  in
  let page_btn p =
    let cls () =
      nav_btn
      ^
      if Signal.get page = p then " bg-neutral-900 text-neutral-0"
      else " text-neutral-700 hover:bg-neutral-100"
    in
    View.element
      ~attrs:[ View.Attr.class_reactive cls ]
      ~events:[ View.On.click (fun _ -> Signal.set page p) ]
      "button"
      [ txt (string_of_int p) ]
  in
  el ~cls:"flex items-center gap-1" "div"
    (arrow "chevron-left" (fun p -> if p > 1 then p - 1 else 1)
     :: List.map page_btn [ 1; 2; 3; 4; 5 ]
    @ [ arrow "chevron-right" (fun p -> if p < 5 then p + 1 else 5) ])

let toolbar_example () =
  el ~cls:"flex w-full max-w-xl items-center gap-1 rounded-lg border border-neutral-200 bg-surface p-1"
    "div"
