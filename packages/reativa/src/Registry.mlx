              [ Icon.make ~name:"trending-up" ~size:`xs ~extra_class:"mr-1" (); txt "12%" ]
            ();
        ];
      el ~cls:"mt-1 text-3xl font-bold text-neutral-900" "p" [ txt "$48.2k" ];
      el ~cls:"mt-3 flex h-8 items-end gap-1" "div"
        (List.map
           (fun v ->
             el ~cls:"flex-1 rounded-sm bg-neutral-300"
               ~attrs:[ View.Attr.make "style" (View.static ("height:" ^ string_of_int v ^ "%")) ]
               "div" [])
           spark);
    ]

let list_example () =
