{
  "name": "ux-archetypes-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "registry": "node scripts/generate-registry.mjs",
    "snippets": "node scripts/generate-snippets.mjs",
    "contracts": "node scripts/generate-contracts.mjs",
    "traits": "node scripts/generate-traits.mjs",
    "tokens": "node scripts/generate-tokens-css.mjs",
    "tokens:data": "node scripts/generate-tokens-data.mjs",
    "themes": "node scripts/generate-themes.mjs",
    "responsive": "node scripts/generate-responsive.mjs",
    "conformance": "node scripts/check-conformance.mjs",
    "conformance:traits": "node scripts/check-traits.mjs",
    "conformance:composition": "node scripts/check-composition.mjs",
    "conformance:tokens": "node scripts/check-tokens.mjs",
    "conformance:responsive": "node scripts/check-responsive.mjs",
    "checks": "npm run conformance && npm run conformance:traits && npm run conformance:composition && npm run conformance:tokens && npm run conformance:responsive",
    "gen": "npm run tokens && npm run tokens:data && npm run themes && npm run responsive && npm run contracts && npm run registry && npm run traits && npm run snippets",
    "res:build": "rescript",
    "res:clean": "rescript clean",
    "res:dev": "rescript -w",
    "dev": "npm run gen && npm run res:build && vite",
    "build": "npm run gen && npm run res:build && npm run checks && vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-all.mjs"
  },
  "dependencies": {
    "rescript-signals": "3.1.1",
    "xote": "7.0.0"
  },
  "devDependencies": {
    "@rescript/core": "1.6.1",
    "@tailwindcss/vite": "4.1.14",
    "playwright-core": "1.56",
    "rescript": "12.3.0",
    "tailwindcss": "4.1.14",
    "vite": "7.1.12"
  }
}
