{
  "$description": "UX Archetypes design tokens — a technology-agnostic, monochrome baseline in the W3C Design Tokens (DTCG) format. Projects consume these directly or map them onto their own theme (see website/ for a Tailwind mapping). Aliases use the {group.token} reference syntax.",
  "color": {
    "$type": "color",
    "neutral": {
      "$description": "The single grayscale ramp. Hierarchy comes from value, not hue.",
      "0": { "$value": "#ffffff" },
      "50": { "$value": "#fafafa" },
      "100": { "$value": "#f5f5f5" },
      "200": { "$value": "#e5e5e5" },
      "300": { "$value": "#d4d4d4" },
      "400": { "$value": "#a3a3a3" },
      "500": { "$value": "#737373" },
      "600": { "$value": "#525252" },
      "700": { "$value": "#404040" },
      "800": { "$value": "#262626" },
      "900": { "$value": "#171717" },
      "950": { "$value": "#0a0a0a" },
      "1000": { "$value": "#000000" }
    },
    "ink": { "$value": "{color.neutral.900}", "$description": "Primary foreground/text." },
    "paper": { "$value": "{color.neutral.50}", "$description": "Page background." },
    "surface": { "$value": "{color.neutral.0}", "$description": "Raised surfaces (cards, menus)." },
    "muted": { "$value": "{color.neutral.500}", "$description": "Secondary/subdued text." },
    "border": { "$value": "{color.neutral.200}", "$description": "Hairline borders and dividers." },
    "accent": { "$value": "{color.neutral.900}", "$description": "Primary action / emphasis fill." },
    "accentContrast": { "$value": "{color.neutral.0}", "$description": "Foreground on the accent fill." }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": ["Inter", "ui-sans-serif", "system-ui", "-apple-system", "Segoe UI", "Roboto", "Helvetica", "Arial", "sans-serif"]
      },
      "mono": {
        "$value": ["ui-monospace", "SFMono-Regular", "SF Mono", "Menlo", "Consolas", "Liberation Mono", "monospace"]
      }
    },
    "weight": {
      "$type": "fontWeight",
      "normal": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.25rem" },
      "2xl": { "$value": "1.5rem" },
      "3xl": { "$value": "1.875rem" },
      "4xl": { "$value": "2.25rem" }
    },
    "lineHeight": {
      "$type": "number",
      "tight": { "$value": 1.2 },
      "normal": { "$value": 1.5 },
      "relaxed": { "$value": 1.65 }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "Spacing scale for padding, margin, and gaps.",
    "0": { "$value": "0rem" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" }
  },
  "radius": {
    "$type": "dimension",
    "none": { "$value": "0rem" },
    "sm": { "$value": "0.25rem" },
    "md": { "$value": "0.375rem" },
    "lg": { "$value": "0.5rem" },
    "xl": { "$value": "0.75rem" },
    "2xl": { "$value": "1rem" },
    "full": { "$value": "9999px" }
  },
  "borderWidth": {
    "$type": "dimension",
    "hairline": { "$value": "1px" },
    "thick": { "$value": "2px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": { "color": "rgba(0,0,0,0.05)", "offsetX": "0rem", "offsetY": "1px", "blur": "2px", "spread": "0rem" }
    },
    "md": {
      "$value": { "color": "rgba(0,0,0,0.10)", "offsetX": "0rem", "offsetY": "4px", "blur": "8px", "spread": "-2px" }
    },
    "lg": {
      "$value": { "color": "rgba(0,0,0,0.15)", "offsetX": "0rem", "offsetY": "12px", "blur": "24px", "spread": "-6px" }
    }
  },
  "duration": {
    "$type": "duration",
    "fast": { "$value": "120ms" },
    "base": { "$value": "200ms" },
    "slow": { "$value": "320ms" }
  },
  "zIndex": {
    "$type": "number",
    "base": { "$value": 0 },
    "dropdown": { "$value": 1000 },
    "overlay": { "$value": 1100 },
    "modal": { "$value": 1200 },
    "toast": { "$value": 1300 }
  }
}
